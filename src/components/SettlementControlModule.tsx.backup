      case 'failed':
        return <span className="inline-flex px-3 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">Falhou</span>;
      default:
        return <span className="inline-flex px-3 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">Desconhecido</span>;
    }
  };

  const filteredSettlements = settlements.filter(settlement => {
