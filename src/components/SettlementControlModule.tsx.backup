  const totalPending = settlements.filter(s => s.status === 'pending').reduce((sum, s) => sum + s.settlementAmount, 0);
  const totalFailed = settlements.filter(s => s.status === 'failed').reduce((sum, s) => sum + s.settlementAmount, 0);
  const totalSettlements = settlements.length;

  const handleReconciliation = (data: ReconciliationData) => {
    setLastReconciliation(data);
    console.log('Conciliação realizada:', data);
  };

