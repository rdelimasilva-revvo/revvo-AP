        { id: 'UR002', acquirer: 'Stone', brand: 'Mastercard', originalValue: 20000, settledValue: 19800, settlementDate: '2025-11-03' },
        { id: 'UR003', acquirer: 'Cielo', brand: 'Visa', originalValue: 10000, settledValue: 9900, settlementDate: '2025-11-03' }
