      ]
    },
    {
      id: 7,
      contractId: 'CTR-2025-007',
      date: '2025-11-02',
      client: 'Atacado Brasil',
      settlementAmount: 91080,
      status: 'completed',
      type: 'Garantia',
      receivables: [
